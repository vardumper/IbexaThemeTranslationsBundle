{% extends '@ibexadesign/ui/layout.html.twig' %}

{% form_theme form '@ibexadesign/ui/form_fields.html.twig'  %}

{% block title %}Add a Theme Translations{% endblock %}

{%- block breadcrumbs -%}
    {% include '@ibexadesign/ui/breadcrumbs.html.twig' with { items: [
        { value: 'Admin' },
        { value: 'Manage Theme Translations' },
        { value: 'Add Theme Translations' }
    ]} %}
{%- endblock -%}

{% block context_menu %}
    {% set menu_items %}
        <li class="ibexa-context-menu__item ibexa-adaptive-items__item">
            <a
                href="{{ path('ibexa_theme_translations.list') }}"
                class="btn ibexa-btn ibexa-btn--secondary"
            >
                <span class="ibexa-btn__label">
                    Cancel
                </span>
            </a>
        </li>
    {% endset %}

    {{ include('@ibexadesign/ui/component/context_menu/context_menu.html.twig', {
        menu_items: menu_items,
    }) }}
{% endblock %}

{%- block header -%}
    {% include '@ibexadesign/ui/page_title.html.twig' with {
        title: 'Add Theme Translation',
    } %}
{%- endblock -%}

{%- block content -%}
    <div class="ibexa-edit-content__container">
    {% block create_form %}
        {{ form_start(form) }}
        {% for key, field in form.children %}
            <div class="mb-3">
            {{ form_row(field) }}
            </div>
        {% endfor %}

        {# DeepL auto-translate checkbox #}
        <div class="mb-3" style="margin-top: 8px;">
            <label style="display:flex; align-items:center; gap:8px; cursor:{% if deeplConfigured %}pointer{% else %}not-allowed{% endif %}; opacity:{% if deeplConfigured %}1{% else %}0.5{% endif %};">
                <input type="checkbox"
                       name="auto_translate_deepl"
                       id="auto-translate-deepl"
                       value="1"
                       {% if not deeplConfigured %}disabled{% endif %}
                       style="width:16px; height:16px; flex-shrink:0;">
                <span>
                    Create translations automatically with Automated Translations
                    {% if not deeplConfigured %}
                        <em style="font-size:12px; color:#888;">(Automated Translations service is not configured)</em>
                    {% else %}
                        <em style="font-size:12px; color:#666;">— translates to all other active languages as drafts pending approval</em>
                    {% endif %}
                </span>
            </label>
        </div>

        {{ form_end(form, { 'render_rest': false }) }}
    {% endblock %}
    </div>
{%- endblock content -%}
